{
    "name": "pactole-js",
    "version": "0.2.0",
    "license": "MIT",
    "displayName": "Pactole.js",
    "description": "A TypeScript library for managing lottery results.",
    "author": "Jean-Sébastien CONAN",
    "homepage": "https://cerbernetix.github.io/pactole-js/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cerbernetix/pactole-js.git"
    },
    "bugs": {
        "url": "https://github.com/cerbernetix/pactole-js/issues"
    },
    "keywords": [],
    "engines": {
        "node": ">=20.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md",
        "LICENSE"
    ],
    "main": "dist/index.umd.js",
    "module": "dist/index.es.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        }
    },
    "scripts": {
        "dev": "vite --config vite.config.ts",
        "docs:api": "typedoc --options typedoc.json",
        "build": "npm run build:lib",
        "build:lib": "tsc && vite build --config vite.config.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "prettier --check . && eslint .",
        "lint:report": "eslint . --output-file eslint_report.json --format json",
        "test": "vitest run --config vite.config.ts ",
        "test:watch": "vitest run --config vite.config.ts --watch --coverage --coverage.reporter text",
        "test:coverage": "vitest run --config vite.config.ts --coverage --coverage.reporter text",
        "test:report": "vitest run --config vite.config.ts --coverage --coverage.reporter text --coverage.reporter html && open .coverage/index.html",
        "test:ci": "vitest run --config vite.config.ts --coverage --coverage.reporter text --coverage.reporter clover",
        "prepack": "npm run lint && npm run test && npm run build",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-terser": "^1.0.0",
        "@types/node": "^25.5.0",
        "@vitest/browser": "^4.1.0",
        "@vitest/coverage-v8": "^4.1.0",
        "@vitest/ui": "^4.1.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "terser": "^5.46.0",
        "typedoc": "^0.28.17",
        "typedoc-plugin-markdown": "^4.10.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "fflate": "^0.8.2"
    }
}
